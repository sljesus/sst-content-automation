# ============================================
# SST Content Automation - Variables de entorno
# ============================================

# API Key de n8n (para crear workflows por API)
N8N_API_KEY=TU_N8N_API_KEY_AQUI
N8N_URL=http://localhost:5678
N8N_API_URL=http://localhost:5678/api/v1

# Google AI Studio (VEO3 para generar videos)
GOOGLE_AI_API_KEY=TU_GOOGLE_AI_API_KEY_AQUI

# OpenAI / Gemini (para generar scripts y calificación)
OPENAI_API_KEY=TU_OPENAI_API_KEY_AQUI
GEMINI_API_KEY=TU_GEMINI_API_KEY_AQUI

# WhatsApp Business Cloud
WHATSAPP_PHONE_NUMBER=+525573333862
WHATSAPP_ACCESS_TOKEN=TU_WHATSAPP_ACCESS_TOKEN_AQUI

# Supabase (base de datos para leads)
SUPABASE_URL=TU_SUPABASE_URL_AQUI
SUPABASE_KEY=TU_SUPABASE_ANON_KEY_AQUI

# Buffer (publicación en redes sociales)
BUFFER_ACCESS_TOKEN=TU_BUFFER_ACCESS_TOKEN_AQUI

# Telegram (para notificaciones y modo review)
TELEGRAM_BOT_TOKEN=TU_TELEGRAM_BOT_TOKEN_AQUI
TELEGRAM_CHAT_ID=TU_TELEGRAM_CHAT_ID_AQUI

# Google Sheets (logging de contenido publicado)
GOOGLE_SHEETS_ID=TU_GOOGLE_SHEETS_ID_AQUI

# Notificaciones
NOTIFICATION_EMAIL=contacto@sstmexico.com
